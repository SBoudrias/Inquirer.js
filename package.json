{
  "name": "@inquirer/root",
  "private": true,
  "keywords": [
    "answer",
    "answers",
    "ask",
    "base",
    "cli",
    "command",
    "command-line",
    "confirm",
    "enquirer",
    "generate",
    "generator",
    "hyper",
    "input",
    "inquire",
    "inquirer",
    "interface",
    "iterm",
    "javascript",
    "menu",
    "node",
    "nodejs",
    "prompt",
    "promptly",
    "prompts",
    "question",
    "readline",
    "scaffold",
    "scaffolder",
    "scaffolding",
    "stdin",
    "stdout",
    "terminal",
    "tty",
    "ui",
    "yeoman",
    "yo",
    "zsh"
  ],
  "license": "MIT",
  "author": "Simon Boudrias <admin@simonboudrias.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/SBoudrias/Inquirer.js.git"
  },
  "workspaces": [
    "packages/*",
    "integration/*",
    "internals/*"
  ],
  "type": "module",
  "scripts": {
    "demo": "node --watch-path=packages/ packages/demo/src/index.ts",
    "dev": "turbo watch tsc",
    "prepare": "git config --local include.path ../.gitconfig || true",
    "prepublishOnly": "yarn tsc",
    "prepack": "find packages/* -maxdepth 1 -type f -name 'README*' -exec sed -i '' -e 's/utm_source=github/utm_source=npmjs/g' {} + && find packages/* -maxdepth 1  -type f -name package.json -exec sh -c 'jq \".devDependencies |= with_entries(select(.value != \\\"workspace:*\\\"))\" \"$1\" > \"$1.tmp\" && mv \"$1.tmp\" \"$1\"' _ {} \\;",
    "postpack": "git restore packages/*/package.json packages/*/README.md",
    "setup": "setup-packages && oxfmt . --no-error-on-unmatched-pattern",
    "pretest": "yarn tsc && oxlint && oxfmt --check . && eslint .",
    "test": "vitest --run packages && turbo test",
    "tsc": "turbo tsc && tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lerna-lite/cli": "^5.0.0",
    "@lerna-lite/publish": "^5.0.0",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-oxlint": "^1.58.0",
    "globals": "^17.4.0",
    "isolate-monorepo-package": "workspace:*",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.22.1",
    "setup-packages": "workspace:*",
    "turbo": "^2.9.4",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "nano-staged": {
    "*": "yarn oxfmt --no-error-on-unmatched-pattern",
    "*.m?[jt]sx?": [
      "yarn oxlint --fix",
      "yarn eslint --fix"
    ]
  },
  "engines": {
    "node": ">=23.5.0 || ^22.13.0 || ^21.7.0 || ^20.12.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
